<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- IMAGE + FAVORITE -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="250dp">

            <ImageView
                android:id="@+id/imgSanPham"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher" />

            <ImageView
                android:id="@+id/imgYeuThich"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentRight="true"
                android:layout_margin="10dp"
                android:background="#AAFFFFFF"
                android:padding="5dp"
                android:src="@android:drawable/btn_star_big_off" />
        </RelativeLayout>

        <!-- PRODUCT INFO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp">

            <!-- SALE LABEL -->
            <TextView
                android:id="@+id/tvNhanSale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SALE"
                android:textColor="#FFFFFF"
                android:background="#E53935"
                android:padding="4dp"
                android:textSize="12sp"
                android:visibility="gone"/>

            <!-- NAME -->
            <TextView
                android:id="@+id/tvTenSP"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên sản phẩm"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginTop="6dp"/>

            <!-- BRAND -->
            <TextView
                android:id="@+id/tvThuongHieu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thương hiệu"
                android:textColor="#757575"
                android:layout_marginTop="4dp"/>

            <!-- PRICE -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tvGia"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100.000 đ"
                    android:textColor="#E53935"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvGiaGoc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="150.000 đ"
                    android:textColor="#999999"
                    android:textSize="14sp"
                    android:layout_marginLeft="10dp"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- STOCK -->
            <TextView
                android:id="@+id/tvSoLuong"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Còn lại: 10 đôi"
                android:textColor="#4CAF50"
                android:layout_marginTop="6dp"/>

            <!-- RATING -->
            <TextView
                android:id="@+id/tvSoSao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="★ 0 đánh giá"
                android:textColor="#FFA000"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- DESCRIPTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giới thiệu sản phẩm"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvGioiThieu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mô tả sản phẩm..."
                android:layout_marginTop="6dp"
                android:textColor="#555"/>
        </LinearLayout>

        <!-- REVIEW LIST -->
        <ListView
            android:id="@+id/lvDanhGia"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="10dp"
            android:background="#FFFFFF"
            android:focusable="false"/>

        <!-- BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp"
            android:background="#FFFFFF"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btnThemGio"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Thêm giỏ"
                android:background="#FF9800"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/btnMuaNgay"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Mua ngay"
                android:background="#4CAF50"
                android:textColor="#FFFFFF"
                android:layout_marginLeft="10dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
