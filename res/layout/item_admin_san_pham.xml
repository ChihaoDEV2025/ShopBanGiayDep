<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_admin_card"
    android:padding="12dp">

    <ImageView
        android:id="@+id/imgSP"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_centerVertical="true"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery" />

    <TextView
        android:id="@+id/tvMaSP"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="4dp"
        android:layout_toRightOf="@id/imgSP"
        android:textColor="@color/admin_text_muted"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/tvTenSP"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvMaSP"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="2dp"
        android:layout_toLeftOf="@+id/layoutBtn"
        android:layout_toRightOf="@id/imgSP"
        android:maxLines="2"
        android:textColor="@color/admin_text"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvGia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvTenSP"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="4dp"
        android:layout_toRightOf="@id/imgSP"
        android:textColor="@color/admin_accent_orange"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvSoLuong"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="4dp"
        android:layout_marginLeft="10dp"
        android:layout_toRightOf="@id/imgSP"
        android:textColor="@color/admin_text_muted"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvTrangThai"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="4dp"
        android:layout_marginLeft="10dp"
        android:layout_toRightOf="@id/tvSoLuong"
        android:textSize="12sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/layoutBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnSua"
            android:layout_width="60dp"
            android:layout_height="34dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_admin_button_primary"
            android:text="Sửa"
            android:textColor="@android:color/white"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnXoa"
            android:layout_width="60dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_admin_button_danger"
            android:text="Xóa"
            android:textColor="@android:color/white"
            android:textSize="11sp" />
    </LinearLayout>

</RelativeLayout>
