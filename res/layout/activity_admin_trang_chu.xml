<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/admin_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_admin_header"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bảng điều khiển"
                android:textColor="#DDE7FF"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvTenAdmin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Xin chào, Admin"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTongSanPham"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:background="@color/admin_success"
                android:gravity="center"
                android:padding="10dp"
                android:text="0&#10;Sản phẩm"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTongDonHang"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_marginLeft="10dp"
                android:layout_weight="1"
                android:background="@color/admin_info"
                android:gravity="center"
                android:padding="10dp"
                android:text="0&#10;Đơn hàng"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTongNguoiDung"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:background="@color/admin_warning"
                android:gravity="center"
                android:padding="10dp"
                android:text="0&#10;Khách hàng"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDoanhThuHomNay"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_marginLeft="10dp"
                android:layout_weight="1"
                android:background="@color/admin_accent_pink"
                android:gravity="center"
                android:padding="10dp"
                android:text="0 đ&#10;Hôm nay"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnQuanLySanPham"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_admin_button_outline"
            android:text="Quản lý sản phẩm"
            android:textAllCaps="false"
            android:textColor="@color/admin_text"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnQuanLyDonHang"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_admin_button_outline"
            android:text="Quản lý đơn hàng"
            android:textAllCaps="false"
            android:textColor="@color/admin_text"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnQuanLyNguoiDung"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_admin_button_outline"
            android:text="Quản lý người dùng"
            android:textAllCaps="false"
            android:textColor="@color/admin_text"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnQuanLyChiTieu"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_admin_button_outline"
            android:text="Quản lý chi tiêu"
            android:textAllCaps="false"
            android:textColor="@color/admin_text"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnThongKe"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_admin_button_outline"
            android:text="Thống kê"
            android:textAllCaps="false"
            android:textColor="@color/admin_text"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnDangXuat"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_admin_button_danger"
            android:text="Đăng xuất"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
