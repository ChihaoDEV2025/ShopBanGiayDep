<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:text="Tên sản phẩm *"
            android:textColor="@color/admin_text_muted"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/edtTenSP"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_admin_card"
            android:hint="Nhập tên sản phẩm"
            android:padding="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:text="Giá gốc (đ) *"
            android:textColor="@color/admin_text_muted"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/edtGia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_admin_card"
            android:hint="VD: 1500000"
            android:inputType="numberDecimal"
            android:padding="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:text="Giá sale (đ)"
            android:textColor="@color/admin_text_muted"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/edtGiaSale"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_admin_card"
            android:hint="VD: 990000"
            android:inputType="numberDecimal"
            android:padding="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:text="Ảnh (file trong assets/images/)"
            android:textColor="@color/admin_text_muted"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/edtImageURL"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_admin_card"
            android:hint="VD: images/nike_airforce1.png"
            android:padding="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:text="Thương hiệu"
            android:textColor="@color/admin_text_muted"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/edtThuongHieu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_admin_card"
            android:hint="VD: Nike, Adidas, Vans..."
            android:padding="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:text="Số lượng tồn kho *"
            android:textColor="@color/admin_text_muted"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/edtSoLuong"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_admin_card"
            android:hint="VD: 50"
            android:inputType="number"
            android:padding="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:text="Mô tả sản phẩm"
            android:textColor="@color/admin_text_muted"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/edtGioiThieu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_admin_card"
            android:hint="Nhập mô tả..."
            android:minLines="2"
            android:padding="8dp" />

        <CheckBox
            android:id="@+id/cbDangBan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Đang bán"
            android:textColor="@color/admin_text"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>
